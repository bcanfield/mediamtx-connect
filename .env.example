# MediaMTX Connect Environment Variables
# Copy this file to .env and customize as needed.

# ===========================================
# Database
# ===========================================

# SQLite database URL (relative to project root for local dev)
DATABASE_URL="file:./src/lib/prisma/database.db"

# ===========================================
# MediaMTX Connect Settings
# ===========================================
# These configure the app on first boot and feed local dev (`npm run dev`).
# Production defaults (matching the published Docker image) live in src/lib/env.ts —
# you only need to set these for local development or to override the seeded Config.

# How this process reaches MediaMTX. For `npm run dev` use localhost; in the
# bundled Docker compose stack the container reaches MediaMTX at http://mediamtx.
BACKEND_SERVER_MEDIAMTX_URL=http://localhost

# MediaMTX API port
# MEDIAMTX_API_PORT=9997

# Browser-facing URL for HLS playback
# REMOTE_MEDIAMTX_URL=http://localhost

# Local paths for recordings / screenshots. Also consumed by docker-compose to
# decide which host directory to mount into the container.
MEDIAMTX_RECORDINGS_DIR=./test-data/recordings
MEDIAMTX_SCREENSHOTS_DIR=./test-data/screenshots

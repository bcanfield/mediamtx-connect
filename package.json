{
  "name": "mediamtx-connect",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build && rm -rf apps/api/public && cp -R apps/web/dist apps/api/public",
    "typecheck": "turbo typecheck",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "i18n:check": "pnpm run i18n:check:messages && pnpm run i18n:check:readme",
    "i18n:check:messages": "node scripts/i18n-check.mjs",
    "i18n:check:readme": "node scripts/readme-i18n-check.mjs",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "mediamtx": "./scripts/start-mediamtx.sh",
    "mediamtx:stop": "docker compose -f docker-compose.dev.yml --profile streams down",
    "dev:all": "./scripts/dev-all.sh",
    "setup": "./scripts/setup-dev.sh",
    "setup:test-data": "./scripts/setup-test-data.sh",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@axe-core/playwright": "^4.11.3",
    "@eslint-react/eslint-plugin": "catalog:",
    "@playwright/test": "^1.57.0",
    "@semantic-release-plus/docker": "^3.1.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "semantic-release": "^25.0.2",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}

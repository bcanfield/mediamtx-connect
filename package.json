{
  "name": "mediamtx-connect",
  "private": true,
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predev": "node scripts/seed-fixtures.mjs",
    "dev": "docker compose -f docker-compose.dev.yml up -d && turbo dev",
    "dev:stop": "docker compose -f docker-compose.dev.yml down",
    "build": "turbo build && rm -rf apps/api/public && cp -R apps/web/dist apps/api/public",
    "typecheck": "turbo typecheck",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "i18n:check": "pnpm run i18n:check:messages && pnpm run i18n:check:readme",
    "i18n:check:messages": "node scripts/i18n-check.mjs",
    "i18n:check:readme": "node scripts/readme-i18n-check.mjs",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@axe-core/playwright": "catalog:",
    "@eslint-react/eslint-plugin": "catalog:",
    "@playwright/test": "catalog:",
    "@semantic-release-plus/docker": "catalog:",
    "@semantic-release/changelog": "catalog:",
    "@semantic-release/exec": "catalog:",
    "@semantic-release/git": "catalog:",
    "conventional-changelog-conventionalcommits": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "semantic-release": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
